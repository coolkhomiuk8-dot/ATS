VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: override Netlify Function paths if you host endpoints elsewhere
VITE_DRIVE_UPLOAD_ENDPOINT=/.netlify/functions/driveUpload
VITE_DRIVE_DELETE_ENDPOINT=/.netlify/functions/driveDelete

# NOTE: variables below are SERVER-ONLY (Netlify Environment Variables), do not expose in client .env
# FIREBASE_SERVICE_ACCOUNT_JSON={...firebase admin sdk json...}
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={...google service account json with Drive API enabled...}
# GOOGLE_DRIVE_ROOT_FOLDER_NAME=ats-storage
# GOOGLE_DRIVE_ROOT_FOLDER_ID=your_shared_drive_folder_id
